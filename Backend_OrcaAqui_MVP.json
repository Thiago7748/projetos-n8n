    {
      "id": "code_prepare",
      "name": "Preparar Dados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [672, 704],
      "parameters": {
        "jsCode": "const id_pedido = $node[\"Webhook Analise IA\"].json.query.id_pedido;\nconst propostas = $input.all().filter(item => item.json.id_pedido == id_pedido);\n\nif (propostas.length === 0) {\n  return [{ json: { tem_propostas: false, id_pedido } }];\n} else {\n  return [{ json: { tem_propostas: true, data: propostas.map(p => p.json) } }];\n}"
      }
    },
