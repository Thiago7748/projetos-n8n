      "name": "Tem Propostas?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [864, 704],
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "id": "1a2b3c",
              "leftValue": "={{ $json.tem_propostas }}",
              "operator": {
