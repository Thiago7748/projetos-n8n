        "jsonBody": "={{ { \"contents\": [{ \"parts\": [{ \"text\": \"Você é um analista de compras. Analise as propostas no array JSON a seguir e diga de forma super resumida (máx 3 parágrafos) qual é a melhor e o porquê.\\n\\nPropostas:\\n\" + JSON.stringify($json.data) }]}] } }}",
